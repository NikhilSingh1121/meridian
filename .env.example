# Optional — enables AI-written report narratives (thesis, SWOT, Porter, risks).
# Without it, the platform uses its deterministic commentary engine.
# Get a key at https://console.anthropic.com → copy this file to .env
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional — enables the Earnings Call module to fetch real transcripts.
# Get a key at https://api-ninjas.com/register (free tier returns the raw transcript;
# Meridian computes sentiment, guidance, competitor & risk analysis on top).
API_NINJAS_KEY=
# Optional — alternative earnings source: Financial Modeling Prep.
# Provides earnings estimates (next report date, consensus EPS/revenue),
# Business Segment Analysis in Equity Research (revenue by segment/geography) and,
# on plans that include it, earnings-call transcripts. Get a key at financialmodelingprep.com
FMP_API_KEY=
PORT=3000

# ── Sign in with Google (Portfolio & Library are saved per-user) ──
# SESSION_SECRET signs login cookies. REQUIRED in production — without it a
# random secret is generated on each boot, logging everyone out on redeploy.
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
# The public OAuth client id. Optional — defaults to the project's registered
# web client if unset. (This is NOT secret; it ships in the frontend.)
GOOGLE_CLIENT_ID=
# NOTE: The Google *client secret* is NOT used by this login (ID-token) flow and
# should never be committed or placed in frontend code. Leave it out unless you
# later add server-side Google API access (authorization-code flow).

# ── Razorpay (Support Meridian button + Community Goal widget) ──
# Get keys at https://dashboard.razorpay.com/app/keys.
# The KEY_ID is public (returned to the browser). The KEY_SECRET is server-only.
# Without these, the two Support buttons show a friendly "launching shortly" note
# and the Community Goal widget displays ₹0 / target with 0 contributors.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret — set the same value in your Razorpay dashboard webhook config
# (Dashboard → Settings → Webhooks → subscribe to "payment.captured", URL:
#  https://mterminal.onrender.com/api/support/webhook). Without this, incoming
# webhooks are rejected (which is safe — /verify still records payments made
# in-app; webhooks are just an extra reliability layer that survives Render's
# ephemeral filesystem across redeploys).
RAZORPAY_WEBHOOK_SECRET=
# Community goal target in INR. Defaults to 10000.
SUPPORT_GOAL_INR=10000
# Guardrails on the custom-amount input.
SUPPORT_MIN_INR=1
SUPPORT_MAX_INR=100000\n